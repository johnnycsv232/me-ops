{
  "project_name": "me_ops",
  "version": "1.0.0",
  "structure": {
    "directories": [
      "data",
      "output",
      "scripts",
      "tests",
      "sources",
      ".githooks"
    ],
    "critical_files": [
      "me_ops.duckdb",
