#!/usr/bin/env bash
# ============================================================
# Pre-Commit Quality Gate
# Skill used: git-advanced-workflows, python-pro
# ============================================================
set -euo pipefail

# -------------------------------------------------------
# GUARD 0: Nested Git Detection
# Prevents the repo from living inside another git repo.
# -------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
PARENT_DIR="$(dirname "$REPO_ROOT")"

# Walk up from parent looking for a .git directory
CHECK_DIR="$PARENT_DIR"
while [ "$CHECK_DIR" != "/" ]; do
    if [ -d "$CHECK_DIR/.git" ]; then
        echo ""
        echo "🚨 NESTED GIT REPO DETECTED"
        echo "   This repo:   $REPO_ROOT"
        echo "   Parent repo: $CHECK_DIR/.git"
        echo ""
        echo "   A parent directory contains a .git directory."
        echo "   This WILL cause confusion about which repo owns your files."
        echo ""
        echo "   FIX: Remove the parent .git:"
        echo "     rm -rf $CHECK_DIR/.git"
        echo ""
        echo "❌ COMMIT BLOCKED — resolve nested git first."
        exit 1
    fi
    CHECK_DIR="$(dirname "$CHECK_DIR")"
done

# -------------------------------------------------------
# GUARD 1: No child .git directories (submodule-less repos)
# -------------------------------------------------------
CHILD_GITS="$(find "$REPO_ROOT" -mindepth 2 -maxdepth 4 -name ".git" -type d 2>/dev/null || true)"
if [ -n "$CHILD_GITS" ]; then
    echo ""
    echo "🚨 CHILD GIT REPO(S) DETECTED inside this project:"
    echo "$CHILD_GITS" | while read -r g; do echo "   → $g"; done
    echo ""
    echo "   If intentional, register as a submodule."
    echo "   Otherwise remove: rm -rf <path>/.git"
    echo ""
    echo "❌ COMMIT BLOCKED — resolve child git repo(s) first."
    exit 1
fi

# -------------------------------------------------------
# GUARD 2: Python staged-file checks
# -------------------------------------------------------
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    echo "✅ Pre-commit passed (no Python files staged)."
    exit 0
fi

echo "🔍 Pre-commit checks on staged Python files..."

ISSUES=0

# Check for debug artifacts
for f in $STAGED_PY; do
    if grep -nE "(breakpoint\(\)|import pdb|pdb\.set_trace|print\(.*DEBUG)" "$f" 2>/dev/null; then
        echo "❌ Debug artifact found in $f"
        ISSUES=$((ISSUES + 1))
    fi
done

# Check for secrets patterns
for f in $STAGED_PY; do
    if grep -nEi "(api_key|secret_key|password|token)\s*=\s*['\"][^'\"]+['\"]" "$f" 2>/dev/null; then
        echo "❌ Possible hardcoded secret in $f"
        ISSUES=$((ISSUES + 1))
    fi
done

# Check for syntax errors
for f in $STAGED_PY; do
    if ! python3 -c "import py_compile; py_compile.compile('$f', doraise=True)" 2>/dev/null; then
        echo "❌ Syntax error in $f"
        ISSUES=$((ISSUES + 1))
    fi
done

if [ $ISSUES -gt 0 ]; then
    echo ""
    echo "❌ PRE-COMMIT FAILED: $ISSUES issue(s) found. Fix before committing."
    exit 1
fi

echo "✅ All pre-commit checks passed."
exit 0
